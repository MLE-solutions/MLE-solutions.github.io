---
interface Props {
  title: string;
  description: string;
  tags?: string[];
  image?: string;
}

const {
  title,
  description,
  tags = [],
  image
} = Astro.props;

---

<article
  class="
    border
    border-[#284d3c]
    rounded-lg
    overflow-hidden
    bg-[#10251d]
  "
>

  {
    image && (
      <img
        src={image}
        alt={title}
        class="
          w-full
          h-48
          object-cover
        "
      />
    )
  }


  <div class="p-6">

    <h3
      class="
        font-mono
        text-xl
        text-[#d4a72c]
      "
    >
      {title}
    </h3>


    <p
      class="
        mt-3
        text-[#d8d5cc]
      "
    >
      {description}
    </p>


    <div
      class="
        mt-4
        flex
        flex-wrap
        gap-2
      "
    >

      {
        tags.map(tag => (
          <span
            class="
              text-xs
              font-mono
              border
              border-[#5b8c5a]
              px-2
              py-1
              rounded
              text-[#9ac98d]
            "
          >
            {tag}
          </span>
        ))
      }

    </div>

  </div>


</article>
