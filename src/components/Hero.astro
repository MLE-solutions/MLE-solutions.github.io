---
const companyName = "MLE Consulting";
---

<section
  id="hero"
  class="
    min-h-[70vh]
    text-mainheading
    flex
    items-center
    justify-center
  "
>

  <div class="max-w-5xl px-6">

    <!-- Company name -->
    <h1
      class="
        text-5xl
        md:text-7xl
        font-sora
        text-mainheading
      "
    >
      {companyName}
    </h1>




    <!-- Rest of hero -->
    <div
      id="hero-content"
      class="
        opacity-0
        transition-opacity
        duration-1000
        mt-10
      "
    >

      <h2
        class="
          text-3xl
	  font-manrope
          text-secondheading
        "
      >
       Scientific Solutions for Ambitious Ideas.  
      </h2>


      <p
        class="
          mt-5
          max-w-xl
	  font-manrope
          text-body
        "
      >
       From startups to supercolliders, we thrive on problems that don't have Google answers. 
      </p>

    </div>
    <!-- Terminal animation -->
    <div
      id="terminal"
      class="
        mt-8
        font-terminal
        text-lg
        text-terminal
      "
    >

      <div id="terminal-output">
        <div id="cursor-line">
          <span class="cursor">█</span>
        </div>
      </div>
    <button
      id="skip-boot"
      class="
        mt-6
        font-mono
        text-sm
        text-terminal
        hover:text-mainheading
        transition-colors
      "
    >
      [ ESC ] Skip Boot
    </button>

    </div>

  </div>

</section>


<script>
const terminalCTA =
  "SYSTEM READY — INITIATE NEW CHALLENGE";
const companyEmail = "mailto:mle.consultants.llc@gmail.com";
const terminalLines = [
  "> loading_company_profile...",
  "> indexing_selected_projects...",
  "> identifying_founders...",
  "> opening_communication_channels..."
];

const sectionIds = [
  "about",
  "projects",
  "founders",
  "contact"
];
let bootFinished = false;
let skipBoot = false;

const sleep = (ms) =>
  new Promise(resolve => setTimeout(resolve, ms));

async function sleepOrSkip(ms) {

    if (skipBoot) return;

    await sleep(ms);

}

function shouldSkipBoot() {

    return window.location.hash !== "";

}

function scrollToHash() {

    const hash = window.location.hash;

    if (!hash)
        return;


    const target =
        document.querySelector(hash);


    if (target) {

        setTimeout(() => {

            target.scrollIntoView({
                behavior: "smooth"
            });

        }, 100);

    }

}

async function blinkCursor(cursor, times = 2) {

  cursor.classList.add("cursor-idle");

  await sleepOrSkip(times * 1200);

  cursor.classList.remove("cursor-idle");

}

async function typeLine(element, text) {
    for (const char of text) {
    
        element.textContent += char;
    
        await sleepOrSkip(40);
    
    }
}

async function renderTerminalCTA() {

    const output =
        document.querySelector("#terminal-output");

    if (!output)
        return;


    const lineElement =
        document.createElement("a");

    lineElement.href =
        companyEmail;

    lineElement.className =
        "terminal-link terminal-ready";


    output.appendChild(lineElement);


    const cursor =
        document.createElement("span");

    cursor.className =
        "cursor";

    cursor.textContent =
        "█";


    // type text first
    await typeLine(
        lineElement,
       terminalCTA 
    );


    // put cursor immediately after text
    lineElement.appendChild(cursor);


    cursor.classList.add(
        "cursor-idle"
    );

}
function revealAllSections() {

    document
      .querySelectorAll(".boot-section")
      .forEach(section =>
        section.classList.add("visible"));

    document
      .querySelector("#hero-content")
      ?.classList.remove("opacity-0");

    bootFinished = true;

}
function bypassBootSequence() {

    renderCompletedTerminal();

    revealAllSections();


    document
      .getElementById("skip-boot")
      ?.remove();


    bootFinished = true;

}

function renderCompletedTerminal() {

    const output =
        document.getElementById("terminal-output");

    if (!output)
        return;


    output.innerHTML = "";


    terminalLines.forEach((line, i) => {

        const lineElement =
            document.createElement("a");

        lineElement.href = `#${sectionIds[i]}`;

        lineElement.className =
            "terminal-link terminal-ready";


        lineElement.textContent = line;


        output.appendChild(lineElement);

    });
	const cta =
	    document.createElement("a");
	
	cta.href =
	    companyEmail;
	
	cta.className =
	    "terminal-link terminal-ready";
	
	cta.textContent = terminalCTA;
	
	output.appendChild(cta);
	const cursor =
	    document.createElement("span");
	
	cursor.className = "cursor cursor-idle";
	cursor.textContent = "█";
	cta.appendChild(cursor);
	
	output.appendChild(cta);	
}

window.finishBoot = function () {
    if (bootFinished) return;
	
    skipBoot = true;

};


async function runTerminalAnimation() {
  const output = document.querySelector("#terminal-output");
  const content = document.querySelector("#hero-content");

  if (!output || !content)
    return;


  let cursor = document.querySelector(".cursor");
  for(let i = 0; i < terminalLines.length; i++){
    const line = terminalLines[i];
    // remove old cursor
    cursor.remove();


    // create new line
    const lineElement =
      document.createElement("a");
    lineElement.href = `#${sectionIds[i]}`;
    lineElement.className =
    "terminal-link";
    output.appendChild(lineElement);


    // create cursor for this line
    cursor =
      document.createElement("span");


    cursor.className = "cursor";

    cursor.textContent = "█";


    lineElement.appendChild(cursor);


    // blink before typing - times regulates speed of line appearances
    await blinkCursor(cursor, 0.5);


    // remove cursor while typing
    cursor.remove();


    await typeLine(lineElement, line);
    lineElement.classList.add("terminal-ready");
    
    await sleepOrSkip(250);

    // Reveal matching section
    if(sectionIds[i]){
       const section = document.getElementById(sectionIds[i]);
       if(section){
         section.classList.add("visible");
       }
    }



    // add cursor after text
    if(i != terminalLines.length-1)
	lineElement.appendChild(cursor);

  }


  await sleepOrSkip(250);


  content.classList.remove("opacity-0");
  await renderTerminalCTA();
  
  bootFinished = true;
  
  sessionStorage.setItem(
      "bootComplete",
      "true"
  );
}

document
    .getElementById("skip-boot")
    ?.addEventListener("click", () => {

        if (bootFinished) return;

        window.finishBoot();

    });
document.addEventListener("keydown", (event) => {

    if (event.key === "Escape") {

        if (bootFinished) return;

        window.finishBoot();

    }

});
//enable during deployment to not run animation on multiple visits
if (
    sessionStorage.getItem("bootComplete") ||
    shouldSkipBoot()
) {

    bypassBootSequence();

    scrollToHash();

} else {

    runTerminalAnimation();

}
//runTerminalAnimation();
</script>
