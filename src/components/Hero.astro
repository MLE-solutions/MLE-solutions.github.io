---
const companyName = "YOUR COMPANY NAME";

---

<section
  id="hero"
  class="
    min-h-[70vh]
    bg-[#08110d]
    text-[#f4f1ea]
    flex
    items-center
    justify-center
  "
>

  <div class="max-w-5xl px-6">

    <!-- Company name -->
    <h1
      class="
        text-5xl
        md:text-7xl
        font-mono
        font-bold
        text-[#d4a72c]
      "
    >
      {companyName}
    </h1>




    <!-- Rest of hero -->
    <div
      id="hero-content"
      class="
        opacity-0
        transition-opacity
        duration-1000
        mt-10
      "
    >

      <h2
        class="
          text-3xl
          text-[#d4a72c]
        "
      >
        Advanced AI + Scientific Computing Consulting
      </h2>


      <p
        class="
          mt-5
          max-w-xl
          text-[#d8d5cc]
        "
      >
        Building intelligent systems and solving complex technical problems.
      </p>

    </div>
    <!-- Terminal animation -->
    <div
      id="terminal"
      class="
        mt-8
        font-mono
        text-lg
        text-[#9ac98d]
      "
    >

      <div id="terminal-output">
        <div id="cursor-line">
          <span class="cursor">█</span>
        </div>
      </div>

    </div>

  </div>

</section>


<script>
const terminalLines = [
  "> loading_company_profile...",
  "> indexing_selected_projects...",
  "> identifying_founders...",
  "> opening_communication_channels..."
];

const sectionIds = [
  "about",
  "projects",
  "founders",
  "contact"
];

const sleep = (ms) =>
  new Promise(resolve => setTimeout(resolve, ms));


async function blinkCursor(cursor, times = 2) {

  cursor.classList.add("cursor-idle");

  await sleep(times * 1200);

  cursor.classList.remove("cursor-idle");

}

async function typeLine(element, text) {

  for (const char of text) {

    element.textContent += char;

    await sleep(40);

  }

}


async function runTerminalAnimation() {
console.log("Terminal animation started");
  const output = document.querySelector("#terminal-output");
  const content = document.querySelector("#hero-content");

  if (!output || !content)
    return;


  let cursor = document.querySelector(".cursor");
  for(let i = 0; i < terminalLines.length; i++){
    const line = terminalLines[i];
    // remove old cursor
    cursor.remove();


    // create new line
    const lineElement =
      document.createElement("div");


    output.appendChild(lineElement);


    // create cursor for this line
    cursor =
      document.createElement("span");


    cursor.className = "cursor";

    cursor.textContent = "█";


    lineElement.appendChild(cursor);


    // blink before typing - times regulates speed of line appearances
    await blinkCursor(cursor, 0.5);


    // remove cursor while typing
    cursor.remove();


    await typeLine(lineElement, line);
    await sleep(250);

    // Reveal matching section
console.log("Looking for:", sectionIds[i]);
    if(sectionIds[i]){
       const section = document.getElementById(sectionIds[i]);
       console.log(section);
       if(section){
         section.classList.add("visible");
       }
    }



    // add cursor after text
    lineElement.appendChild(cursor);

  }


  await sleep(250);


  content.classList.remove("opacity-0");
  cursor.classList.add("cursor-idle");

}


runTerminalAnimation();
</script>
