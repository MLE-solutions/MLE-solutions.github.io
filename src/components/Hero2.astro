---
/*
  Hero.astro

  Replace:
  - companyName
  - tagline
  - description
  - buttons
  - logo placeholder

  Later we can add:
  - animated toad SVG
  - CRT effects
  - glitch text
  - terminal animations
*/

const companyName = "YOUR COMPANY NAME";

const tagline = "Advanced AI + Scientific Computing Consulting";

const description =
  "We build intelligent systems, solve complex technical problems, and help organizations transform ideas into reliable technology.";

const statusMessage = "SYSTEM ONLINE // ACCEPTING NEW PROJECTS";
---

<section
  class="
    relative
    min-h-screen
    overflow-hidden
    bg-[#08110d]
    text-[#f4f1ea]
    flex
    items-center
  "
>

  <!-- Retro background grid -->
  <div
    class="
      absolute
      inset-0
      opacity-20
      bg-[linear-gradient(#5b8c5a_1px,transparent_1px),
      linear-gradient(90deg,#5b8c5a_1px,transparent_1px)]
      bg-[size:40px_40px]
    "
  >
  </div>


  <!-- Main content -->
  <div
    class="
      relative
      z-10
      mx-auto
      max-w-6xl
      px-6
      py-24
      grid
      md:grid-cols-2
      gap-12
      items-center
    "
  >

    <!-- Text -->
    <div>

      <!-- Status badge -->
      <div
        class="
          inline-flex
          items-center
          gap-2
          border
          border-[#5b8c5a]
          bg-[#10251d]
          px-4
          py-2
          rounded
          font-mono
          text-xs
          tracking-widest
          text-[#9ac98d]
        "
      >

        <span class="animate-pulse">
          ●
        </span>

        {statusMessage}

      </div>


      <!-- Company name -->
      <h1
        class="
          mt-8
          text-5xl
          md:text-7xl
          font-bold
          tracking-tight
          font-mono
        "
      >

        {companyName}

      </h1>


      <!-- Decorative divider -->
      <div
        class="
          my-6
          h-px
          w-full
          bg-gradient-to-r
          from-[#d4a72c]
          via-[#5b8c5a]
          to-transparent
        "
      >
      </div>


      <!-- Tagline -->
      <h2
        class="
          text-2xl
          md:text-3xl
          font-semibold
          text-[#d4a72c]
        "
      >

        {tagline}

      </h2>


      <!-- Description -->
      <p
        class="
          mt-6
          max-w-xl
          text-lg
          leading-relaxed
          text-[#d8d5cc]
        "
      >

        {description}

      </p>


      <!-- Fake terminal text -->
      <div
        class="
          mt-8
          rounded-lg
          border
          border-[#284d3c]
          bg-black/40
          p-5
          font-mono
          text-sm
          text-[#9ac98d]
        "
      >

        <p>
          > initializing consultation_engine...
        </p>

        <p>
          > loading machine_learning_modules...
        </p>

        <p>
          > ready_for_new_challenges_
        </p>

      </div>


      <!-- Buttons -->
      <div
        class="
          mt-8
          flex
          flex-wrap
          gap-4
        "
      >

        <a
          href="#projects"
          class="
            border
            border-[#d4a72c]
            bg-[#d4a72c]
            px-6
            py-3
            font-mono
            text-black
            rounded
            hover:bg-[#f0c94d]
            transition
          "
        >
          VIEW PROJECTS
        </a>


        <a
          href="#contact"
          class="
            border
            border-[#5b8c5a]
            px-6
            py-3
            font-mono
            rounded
            hover:bg-[#10251d]
            transition
          "
        >
          CONTACT
        </a>

      </div>

    </div>



    <!-- Mascot / logo area -->
    <div
      class="
        flex
        justify-center
      "
    >

      <div
        class="
          relative
          h-72
          w-72
          rounded-full
          border
          border-[#5b8c5a]
          bg-[#10251d]
          flex
          items-center
          justify-center
          shadow-[0_0_50px_rgba(91,140,90,0.35)]
        "
      >

        <!-- Replace with actual toad SVG -->

        <div
          class="
            text-8xl
            grayscale
            opacity-80
          "
        >
          🐸
        </div>


        <div
          class="
            absolute
            bottom-5
            font-mono
            text-xs
            text-[#9ac98d]
          "
        >

          TOAD_AI_UNIT_v1.0

        </div>

      </div>

    </div>


  </div>


</section>
