---
interface Props {
  id?: string;
  title?: string;
  subtitle?: string;
}

const {
  id,
  title,
  subtitle
} = Astro.props;
---

<section
  id={id}
  class="
    mx-auto
    max-w-6xl
    px-6
    py-20
  "
>

  {
    title && (
      <h2
        class="
          text-3xl
          md:text-4xl
          font-mono
          text-[#d4a72c]
          mb-4
        "
      >
        {title}
      </h2>
    )
  }


  {
    subtitle && (
      <p
        class="
          text-[#d8d5cc]
          mb-8
        "
      >
        {subtitle}
      </p>
    )
  }


  <slot />

</section>
