import Hero from "../components/Hero.astro";
import Section from "../components/Section.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout>

<Navbar />

<Hero />

<Section
  id="about"
  sectionClass="boot-section"
  title="ABOUT"
  subtitle="Company thesis goes here."
>
</Section>


<Section
  id="projects"
  sectionClass="boot-section"
  title="PROJECTS"
>
</Section>


<Section
  id="founders"
  sectionClass="boot-section"
  title="FOUNDERS"
>
</Section>


<Section
  id="contact"
  sectionClass="boot-section"
  title="CONTACT"
>
</Section>


<Footer />

</BaseLayout>
